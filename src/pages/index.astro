---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const products = await getCollection('products');
---

<Layout>
  <h2>Products Catalog</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
    {products.map(product => (
      <div style="background: white; padding: 1rem; border-radius: 8px; border: 1px solid #ccc;">
        <h3><a href={`/products/${product.id}`} style="text-decoration: none; color: var(--accent);">{product.data.title}</a></h3>
        <p>SKU: <strong>{product.data.sku}</strong></p>
        <p>{product.body.slice(0, 100)}...</p>
      </div>
    ))}
  </div>
</Layout>
