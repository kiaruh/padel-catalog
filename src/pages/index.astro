---
import Layout from '../layouts/Layout.astro';
import ModelViewer from '../components/ModelViewer.astro';
---
<Layout>
  <style is:inline>
    :root{
      --accent:#1574d4;
      --accent-deep:#0d56a3;
      --ink:#0c1a2b;
      --ink-2:#42566c;
      --paper:#eaeef3;
      --line:rgba(21,116,212,.16);
      --line-dark:rgba(120,180,255,.13);
    }
    html{scroll-behavior:smooth;}
    body{margin:0;background:#0c1a2b;}
    ::selection{background:#1574d4;color:#fff;}
  </style>
  
  <script is:inline>
    import { trackClick } from '../scripts/track.js';
    window.trackClick = trackClick;
  </script>

  



<div style="--accent:{{ accent }};font-family:'IBM Plex Sans',system-ui,sans-serif;color:var(--ink);background:var(--paper);min-height:100vh;-webkit-font-smoothing:antialiased;overflow-x:hidden;">

  

  <!-- TOP BAR -->
  <div style="position:sticky;top:0;z-index:50;background:rgba(234,238,243,.82);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);">
    <div style="max-width:1200px;margin:0 auto;padding:13px 48px;display:flex;justify-content:space-between;align-items:center;font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;">
      <div style="display:flex;align-items:center;gap:12px;color:var(--ink);font-weight:600;"><span style="width:9px;height:9px;background:var(--accent);display:inline-block;"></span>MINIPÁDEL — Dossier técnico</div>
      <div style="color:var(--ink-2);">PM-01 · v0.1 · Confidencial</div>
    </div>
  </div>

  <!-- 00 · PORTADA -->
  <section data-screen-label="00 Portada" style="background-color:var(--paper);background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:28px 28px;border-bottom:1px solid var(--line);">
    <div style="max-width:1200px;margin:0 auto;padding:96px 48px 104px;display:grid;grid-template-columns:1.05fr .95fr;gap:64px;align-items:center;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.24em;color:var(--accent);font-weight:600;text-transform:uppercase;margin-bottom:22px;">Sistema modular de mini pádel infantil</div>
        <h1 style="font-size:92px;line-height:.92;letter-spacing:-.03em;font-weight:700;margin:0;color:var(--ink);">MINIPÁDEL</h1>
        <div style="display:flex;align-items:center;gap:14px;margin:20px 0 30px;">
          <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.18em;color:#fff;background:var(--accent);padding:5px 11px;">PROYECTO PM-01</span>
          <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.12em;color:var(--ink-2);">Dossier para proveedores</span>
        </div>
        <p style="font-size:19px;line-height:1.62;color:var(--ink-2);margin:0 0 18px;max-width:540px;">Sistema modular que transforma patios escolares y espacios deportivos en canchas de pádel adaptadas para niños de 5 a 10 años.</p>
        <p style="font-size:17px;line-height:1.62;color:var(--ink-2);margin:0;max-width:540px;">Paneles de policarbonato y marcos de polímero resistente con encastres y cierres rápidos: armado sin herramientas por una o dos personas. Una solución segura, transportable y escalable.</p>
      </div>
      <div>
        <figure style="margin:0;border:1px solid var(--accent);background:#fff;box-shadow:0 24px 60px -28px rgba(12,26,43,.5);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase;">
            <span>FIG.01 — Conjunto general</span><span>Render CAD</span>
          </div>
          <img src="/renders/4638e518-dd6b-44a3-9b08-d8e7176211d1.jpg" alt="Render del sistema modular de mini pádel" style="display:block;width:100%;height:auto;">
        </figure>
      </div>
    </div>
    <!-- spec strip -->
    <div style="max-width:1200px;margin:0 auto;padding:0 48px 64px;">
      <div style="display:flex;flex-wrap:wrap;border:1px solid var(--line);background:#fff;">
        <div style="flex:1;min-width:200px;padding:20px 24px;border-right:1px solid var(--line);">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase;margin-bottom:7px;">Edad objetivo</div>
          <div style="font-size:17px;font-weight:600;color:var(--ink);">5 – 10 años</div>
        </div>
        <div style="flex:1;min-width:200px;padding:20px 24px;border-right:1px solid var(--line);">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase;margin-bottom:7px;">Armado</div>
          <div style="font-size:17px;font-weight:600;color:var(--ink);">Sin herramientas</div>
        </div>
        <div style="flex:1;min-width:200px;padding:20px 24px;border-right:1px solid var(--line);">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase;margin-bottom:7px;">Material</div>
          <div style="font-size:17px;font-weight:600;color:var(--ink);">Policarbonato + polímero</div>
        </div>
        <div style="flex:1;min-width:200px;padding:20px 24px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase;margin-bottom:7px;">Logística</div>
          <div style="font-size:17px;font-weight:600;color:var(--ink);">Transportable y escalable</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 01 · CONTEXTO DE USO -->
  <section data-screen-label="01 Contexto" style="background:#fff;border-bottom:1px solid var(--line);">
    <div style="max-width:1200px;margin:0 auto;padding:104px 48px;">
      <div style="margin-bottom:48px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.22em;color:var(--accent);font-weight:600;margin-bottom:14px;text-transform:uppercase;">Sección 01 / 08</div>
        <h2 style="font-size:42px;line-height:1.04;letter-spacing:-.02em;margin:0 0 16px;color:var(--ink);font-weight:700;">Contexto de uso</h2>
        <p style="max-width:700px;font-size:18px;line-height:1.6;color:var(--ink-2);margin:0;">Pensado para instalarse y retirarse sobre superficies existentes —patios, gimnasios, playones— sin obra civil. Se adapta al espacio disponible sumando o quitando módulos.</p>
      </div>
      <figure style="margin:0 0 56px;border:1px solid var(--accent);background:#fff;">
        <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase;">
          <span>FIG.02 — Implantación en patio escolar</span><span>Visualización en contexto</span>
        </div>
        <img src="/renders/330da32d-f1b3-4f62-9534-6201e31b54fc.jpg" alt="Sistema instalado en patio de escuela" style="display:block;width:100%;height:auto;">
      </figure>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--line);">
        <div style="padding:30px 28px;border-right:1px solid var(--line);">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent);font-weight:600;margin-bottom:14px;">A·01</div>
          <h3 style="font-size:21px;margin:0 0 10px;color:var(--ink);font-weight:600;">Escuelas</h3>
          <p style="font-size:15.5px;line-height:1.6;color:var(--ink-2);margin:0;">Convierte el recreo y la clase de educación física en juego de pádel. Se guarda desarmado cuando no se usa.</p>
        </div>
        <div style="padding:30px 28px;border-right:1px solid var(--line);">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent);font-weight:600;margin-bottom:14px;">A·02</div>
          <h3 style="font-size:21px;margin:0 0 10px;color:var(--ink);font-weight:600;">Clubes</h3>
          <p style="font-size:15.5px;line-height:1.6;color:var(--ink-2);margin:0;">Escuela de iniciación y captación temprana. Cancha reducida para entrenar técnica en grupos chicos.</p>
        </div>
        <div style="padding:30px 28px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent);font-weight:600;margin-bottom:14px;">A·03</div>
          <h3 style="font-size:21px;margin:0 0 10px;color:var(--ink);font-weight:600;">Espacios recreativos</h3>
          <p style="font-size:15.5px;line-height:1.6;color:var(--ink-2);margin:0;">Plazas, centros deportivos y eventos. Montaje rápido para activaciones temporales y ferias.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 02 · PLANOS TÉCNICOS -->
  <section data-screen-label="02 Planos" style="background-color:#0a1422;background-image:linear-gradient(var(--line-dark) 1px,transparent 1px),linear-gradient(90deg,var(--line-dark) 1px,transparent 1px);background-size:40px 40px;color:#dce6f2;border-bottom:1px solid var(--line);">
    <div style="max-width:1200px;margin:0 auto;padding:104px 48px;">
      <div style="margin-bottom:52px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.22em;color:#54a8f0;font-weight:600;margin-bottom:14px;text-transform:uppercase;">Sección 02 / 08</div>
        <h2 style="font-size:42px;line-height:1.04;letter-spacing:-.02em;margin:0 0 16px;color:#fff;font-weight:700;">Planos técnicos</h2>
        <p style="max-width:720px;font-size:18px;line-height:1.6;color:#9fb3c9;margin:0;">Despiece de los seis perfiles y paneles que componen el sistema. Cotas en milímetros. Todos los perfiles comparten una sección base de pared 6–8 mm con ranura de 12 mm para alojar el panel.</p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;">

        <!-- BASE INFERIOR -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 01 · PM-01-A</span><a href="/manuals/2f1cbe6b-b710-4b34-9a45-462d48c10a1c.pdf" download onclick="trackClick('pdf_download', 'base-inferior')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/62a7b9f9-d0f5-4857-bc02-198efc588e13.png" alt="Plano base inferior" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>BASE INFERIOR</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>1000 · 300×249</div>
          </div>
        </figure>

        <!-- BASE SUPERIOR 900 -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 02 · PM-01-B</span><a href="/manuals/ab8eca23-5b27-4da7-a0a0-b09c3ddbcc2d.pdf" download onclick="trackClick('pdf_download', 'base-superior-900')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/919b8b88-84d9-4902-90af-e92db420c72d.png" alt="Plano base superior 900" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>BASE SUPERIOR</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>900 · 136×80</div>
          </div>
        </figure>

        <!-- BASE SUPERIOR REMATE 600 -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 03 · PM-01-B2</span><a href="/manuals/f747ecec-8e56-494d-8081-a941f2fad06d.pdf" download onclick="trackClick('pdf_download', 'base-superior-remate-600')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/9f0ed017-269e-4481-b07c-baaef0a6a029.png" alt="Plano base superior remate 600" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>BASE SUP. (REMATE)</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>600 · 136×80</div>
          </div>
        </figure>

        <!-- ESQUINERO -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 04 · PM-01-C</span><a href="/manuals/a8d61fd0-d66e-462c-bbd2-3670bfc74a53.pdf" download onclick="trackClick('pdf_download', 'esquinero')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/ac8fe109-fefe-4c99-bded-9fcbca82298a.png" alt="Plano esquinero" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>ESQUINERO</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>750×750 · 79×136</div>
          </div>
        </figure>

        <!-- PANEL PRINCIPAL -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 05 · PM-01-D</span><a href="/manuals/3a4bbf46-69fe-47a4-9e2c-58e3fab09888.pdf" download onclick="trackClick('pdf_download', 'panel-principal')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/f5daa8c9-6ef3-4064-872e-261d78f864ab.png" alt="Plano panel principal" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>PANEL PRINCIPAL</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>1000×1308 · e12</div>
          </div>
        </figure>

        <!-- PANEL REJA -->
        <figure style="margin:0;border:1px solid rgba(120,180,255,.3);background:#fff;color:var(--ink);">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.13em;color:var(--accent);text-transform:uppercase;">
            <span>Plano 06 · PM-01-E</span><a href="/manuals/00b92423-a875-4831-8aa1-bb02514cf361.pdf" download onclick="trackClick('pdf_download', 'panel-reja')" target="_blank" rel="noopener" style="color:#fff;background:var(--accent);padding:3px 9px;text-decoration:none;letter-spacing:.1em;" style-hover="background:var(--accent-deep);">VER PDF ↗</a>
          </div>
          <div style="height:300px;display:flex;align-items:center;justify-content:center;padding:18px;"><img src="/renders/ac68b246-32c5-48f0-b471-dcc388c990ce.png" alt="Plano panel reja" style="max-width:100%;max-height:100%;object-fit:contain;"></div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;">
            <div style="padding:11px 14px;border-right:1px solid var(--line);"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DENOMINACIÓN</span>PANEL REJA</div>
            <div style="padding:11px 14px;"><span style="color:var(--accent);display:block;font-size:9.5px;letter-spacing:.14em;margin-bottom:3px;">DIM. PRINCIPAL</span>1000×1308 · malla hex.</div>
          </div>
        </figure>

      </div>
      <p style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#7e93a9;margin:32px 0 0;letter-spacing:.04em;">↳ Planos completos en PDF (CAD) disponibles a pedido — directorio /planos/.</p>
    </div>
  </section>

  <!-- 03 · RENDERS -->
  <section data-screen-label="03 Renders" style="background:var(--paper);border-bottom:1px solid var(--line);">
    <div style="max-width:1200px;margin:0 auto;padding:104px 48px;">
      <div style="margin-bottom:48px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.22em;color:var(--accent);font-weight:600;margin-bottom:14px;text-transform:uppercase;">Sección 03 / 08</div>
        <h2 style="font-size:42px;line-height:1.04;letter-spacing:-.02em;margin:0 0 16px;color:var(--ink);font-weight:700;">Renders</h2>
        <p style="max-width:700px;font-size:18px;line-height:1.6;color:var(--ink-2);margin:0;">Vistas del conjunto armado: cerramiento inferior macizo, franja superior de reja y aberturas laterales de acceso.</p>
      </div>
      <figure style="margin:0 0 28px;border:1px solid var(--accent);background:#fff;">
        <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase;">
          <span>FIG.03 — Vista de módulo en perspectiva</span><span>Render CAD</span>
        </div>
        <img src="/renders/77465422-07db-4e47-bbcf-9dbe438a6755.png" alt="Render del módulo en perspectiva" style="display:block;width:100%;height:auto;background:#fff;">
      </figure>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;">
        <figure style="margin:0;border:1px solid var(--accent);background:#fff;">
          <div style="display:flex;justify-content:space-between;padding:9px 13px;border-bottom:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase;">
            <span>FIG.04 — Conjunto completo</span><span>Render CAD</span>
          </div>
          <img src="/renders/4638e518-dd6b-44a3-9b08-d8e7176211d1.jpg" alt="Render conjunto completo" style="display:block;width:100%;height:auto;">
        </figure>
        <figure style="margin:0;border:1px solid var(--accent);background:#fff;">
