---
const GA_ID = import.meta.env.PUBLIC_GA_ID || 'G-XXXXXXXXXX'; // Fallback for dev if not set
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Minipadel Catalog</title>
  
  {import.meta.env.PROD && GA_ID && (
    <>
      <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script type="text/partytown" define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </>
  )}
</head>
<body>
  <slot />
</body>
</html>
